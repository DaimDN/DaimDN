import { useState, useEffect, useRef } from 'react';
import Sidebar from './components/Sidebar';
import ChatInput from './components/ChatInput';
import ChatMessage from './components/ChatMessage';
import { ChatMessage as ChatMessageType, ChatHistory, WebSocketMessage } from './types/chatTypes';
import './styles.css';

function App() {
  const [messages, setMessages] = useState<ChatMessageType[]>([]);
  const [currentChatId, setCurrentChatId] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState<boolean>(false);
  const [chatHistory, setChatHistory] = useState<ChatHistory>({});
  const messagesEndRef = useRef<HTMLDivElement>(null);
  const ws = useRef<WebSocket | null>(null);

  // WebSocket initialization
  useEffect(() => {
    ws.current = new WebSocket("ws://localhost:3000");

    ws.current.onmessage = (event: MessageEvent<string>) => {
      const data: WebSocketMessage = JSON.parse(event.data);

      if (data.type === "response" && data.content) {
        setMessages(prev => {
          const lastMessage = prev[prev.length - 1];
          if (lastMessage && !lastMessage.isUser) {
            return [
              ...prev.slice(0, -1),
              { ...lastMessage, content: lastMessage.content + data.content }
            ];
          }
          return [...prev, { content: data.content, isUser: false }];
        });
      } else if (data.type === "done") {
        setIsLoading(false);
        saveMessages();
      } else if (data.type === "error" && data.message) {
        setMessages(prev => [...prev, { content: data.message, isUser: false }]);
        setIsLoading(false);
      }
    };

    ws.current.onerror = (error: Event) => {
      console.error("WebSocket error:", error);
      setMessages(prev => [...prev, { 
        content: "Connection error. Please refresh the page.", 
        isUser: false 
      }]);
    };

    return () => {
      if (ws.current) {
        ws.current.close();
      }
    };
  }, []);

  useEffect(() => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, [messages]);

  useEffect(() => {
    const history = JSON.parse(sessionStorage.getItem('AI_chat_history') || '{}') as ChatHistory;
    setChatHistory(history);

    const currentId = sessionStorage.getItem('AI_current_chat');
    if (currentId && history[currentId]) {
      setCurrentChatId(currentId);
      setMessages(history[currentId].messages);
    } else {
      createNewChat();
    }
  }, []);

  const saveMessages = () => {
    if (!currentChatId || messages.length === 0) return;

    const updatedHistory: ChatHistory = { ...chatHistory };
    updatedHistory[currentChatId] = {
      id: currentChatId,
      timestamp: new Date().toISOString(),
      messages: messages
    };

    sessionStorage.setItem('AI_chat_history', JSON.stringify(updatedHistory));
    setChatHistory(updatedHistory);
  };

  const generateChatId = (): string => `chat_${Date.now()}`;

  const createNewChat = (): void => {
    const newChatId = generateChatId();
    setCurrentChatId(newChatId);
    sessionStorage.setItem('AI_current_chat', newChatId);
    setMessages([]);

    setMessages([{ 
      content: "Hello! I'm AI, an AI assistant. How can I help you today?", 
      isUser: false 
    }]);

    const updatedHistory: ChatHistory = { ...chatHistory };
    updatedHistory[newChatId] = {
      id: newChatId,
      timestamp: new Date().toISOString(),
      messages: []
    };
    sessionStorage.setItem('AI_chat_history', JSON.stringify(updatedHistory));
    setChatHistory(updatedHistory);
  };

  const loadChat = (chatId: string): void => {
    if (chatHistory[chatId]) {
      setCurrentChatId(chatId);
      sessionStorage.setItem('AI_current_chat', chatId);
      setMessages(chatHistory[chatId].messages);
    }
  };

  const handleSendMessage = (message: string): void => {
    if (isLoading || !message.trim()) return;

    const newMessage: ChatMessageType = { content: message, isUser: true };
    setMessages(prev => [...prev, newMessage]);
    setIsLoading(true);

    if (ws.current && ws.current.readyState === WebSocket.OPEN) {
      ws.current.send(JSON.stringify({
        type: "chat",
        message: message
      } as WebSocketMessage));
    }
  };

  return (
    <div className="flex h-screen bg-white">
      <Sidebar 
        chatHistory={chatHistory} 
        currentChatId={currentChatId} 
        onCreateNewChat={createNewChat} 
        onLoadChat={loadChat} 
      />
      
      <div className="flex-1 flex flex-col">
        <div className="flex-1 overflow-y-auto p-4 space-y-6">
          {messages.map((msg, index) => (
            <ChatMessage 
              key={index} 
              content={msg.content} 
              isUser={msg.isUser} 
            />
          ))}
          <div ref={messagesEndRef} />
        </div>
        
        <ChatInput 
          onSendMessage={handleSendMessage} 
          isLoading={isLoading} 
        />
      </div>
    </div>
  );
}

export default App;
