import { useEffect } from 'react';
import ClipboardJS from 'clipboard';

const CodeBlock = ({ content }) => {
  useEffect(() => {
    // Initialize clipboard for all copy buttons
    const clipboard = new ClipboardJS('.code-copy');
    
    clipboard.on('success', function(e) {
      const button = e.trigger;
      button.textContent = 'Copied!';
      setTimeout(() => {
        button.textContent = 'Copy';
      }, 2000);
    });

    return () => {
      clipboard.destroy();
    };
  }, []);

  return (
    <div className="space-y-4">
      {content.split(/(```[\s\S]*?```)/).map((part, index) => {
        if (part.startsWith("```") && part.endsWith("```")) {
          const codeContent = part.slice(3, -3);
          const firstLine = codeContent.split('\n')[0];
          const language = firstLine.trim();
          const code = codeContent.slice(language.length + 1).trim();
          const codeId = `code-${index}-${Date.now()}`;

          return (
            <div key={index} className="relative max-w-2xl mx-auto my-4">
              <div className="bg-gray-900 text-white p-4 rounded-md">
                <div className="flex justify-between items-center mb-2">
                  <span className="text-gray-400">{language || "Code"}:</span>
                  <button
                    className="code-copy bg-gray-800 hover:bg-gray-700 text-gray-300 px-3 py-1 rounded-md"
                    data-clipboard-target={`#${codeId}`}
                  >
                    Copy
                  </button>
                </div>
                <div className="overflow-x-auto">
                  <pre className="text-gray-300">
                    <code id={codeId}>{code}</code>
                  </pre>
                </div>
              </div>
            </div>
          );
        } else if (part.trim()) {
          return (
            <div key={index} className="my-2 text-gray-800 whitespace-pre-wrap">
              {part.trim()}
            </div>
          );
        }
        return null;
      })}
    </div>
  );
};

export default CodeBlock;


