const express = require('express');
const cors = require('cors');
const axios = require('axios');

const app = express();
const PORT = process.env.PORT || 3001;

// Middleware
app.use(cors());
app.use(express.json());

// Store Jira configuration (single instance since no auth required)
let jiraConfig = null;

// Configure Jira endpoint
app.post('/api/jira/configure', (req, res) => {
  const { baseUrl } = req.body;
  
  if (!baseUrl) {
    return res.status(400).json({ error: 'Base URL is required' });
  }

  jiraConfig = {
    baseUrl: baseUrl.replace(/\/$/, '') // Remove trailing slash
  };

  res.json({ success: true, message: 'Jira configuration saved' });
});

// Helper function to handle API errors
const handleApiError = (error, res) => {
  if (error.response) {
    const errorMessage = error.response.data?.errorMessages?.[0] || 
                         error.response.data?.message || 
                         `HTTP ${error.response.status}: ${error.response.statusText}`;
    
    return res.status(error.response.status).json({ 
      error: errorMessage,
      details: error.response.data 
    });
  } else if (error.request) {
    return res.status(503).json({ 
      error: 'Unable to connect to Jira server',
      message: 'Please check your Jira URL and network connection' 
    });
  } else {
    return res.status(500).json({ 
      error: 'Internal server error',
      message: error.message 
    });
  }
};

// Get all projects
app.post('/api/jira/projects', async (req, res) => {
  try {
    if (!jiraConfig) {
      return res.status(400).json({ error: 'Jira not configured. Please configure first.' });
    }

    const { baseUrl } = jiraConfig;

    const headers = {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    };

    const response = await axios.get(`${baseUrl}/rest/api/2/project`, {
      headers,
      timeout: 30000
    });

    const projects = response.data.map(project => ({
      id: project.id,
      key: project.key,
      name: project.name,
      projectTypeKey: project.projectTypeKey,
      description: project.description || '',
      lead: project.lead?.displayName || 'Unknown'
    }));

    res.json({ projects });

  } catch (error) {
    console.error('Error fetching projects:', error);
    handleApiError(error, res);
  }
});

// Get all boards for a project
app.post('/api/jira/boards', async (req, res) => {
  try {
    const { projectKey } = req.body;
    
    if (!projectKey) {
      return res.status(400).json({ error: 'Project key is required' });
    }

    if (!jiraConfig) {
      return res.status(400).json({ error: 'Jira not configured. Please configure first.' });
    }

    const { baseUrl } = jiraConfig;

    const headers = {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    };

    // Get boards for the project
    const response = await axios.get(`${baseUrl}/rest/agile/1.0/board`, {
      headers,
      params: {
        projectKeyOrId: projectKey,
        type: 'scrum' // Focus on scrum boards that have sprints
      },
      timeout: 30000
    });

    const boards = response.data.values.map(board => ({
      id: board.id,
      name: board.name,
      type: board.type,
      projectKey: projectKey
    }));

    res.json({ boards });

  } catch (error) {
    console.error('Error fetching boards:', error);
    handleApiError(error, res);
  }
});

// Get all sprints for a board
app.post('/api/jira/sprints', async (req, res) => {
  try {
    const { boardId } = req.body;
    
    if (!boardId) {
      return res.status(400).json({ error: 'Board ID is required' });
    }

    if (!jiraConfig) {
      return res.status(400).json({ error: 'Jira not configured. Please configure first.' });
    }

    const { baseUrl } = jiraConfig;

    const headers = {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    };

    const response = await axios.get(`${baseUrl}/rest/agile/1.0/board/${boardId}/sprint`, {
      headers,
      params: {
        maxResults: 100
      },
      timeout: 30000
    });

    const sprints = response.data.values.map(sprint => ({
      id: sprint.id,
      name: sprint.name,
      state: sprint.state,
      startDate: sprint.startDate,
      endDate: sprint.endDate,
      completeDate: sprint.completeDate,
      boardId: boardId
    }));

    res.json({ sprints });

  } catch (error) {
    console.error('Error fetching sprints:', error);
    handleApiError(error, res);
  }
});

// Get all tickets for a sprint
app.post('/api/jira/sprint-tickets', async (req, res) => {
  try {
    const { sprintId } = req.body;
    
    if (!sprintId) {
      return res.status(400).json({ error: 'Sprint ID is required' });
    }

    if (!jiraConfig) {
      return res.status(400).json({ error: 'Jira not configured. Please configure first.' });
    }

    const { baseUrl } = jiraConfig;

    const headers = {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    };

    const response = await axios.get(`${baseUrl}/rest/agile/1.0/sprint/${sprintId}/issue`, {
      headers,
      params: {
        maxResults: 100,
        fields: 'summary,description,priority,status,assignee,created,updated,reporter,project,issuetype,storypoints'
      },
      timeout: 30000
    });

    const tickets = response.data.issues.map(issue => ({
      key: issue.key,
      summary: issue.fields.summary,
      description: issue.fields.description?.content?.[0]?.content?.[0]?.text || 
                   issue.fields.description || 
                   'No description available',
      priority: issue.fields.priority?.name || 'None',
      status: issue.fields.status?.name || 'Unknown',
      assignee: issue.fields.assignee?.displayName || 'Unassigned',
      created: issue.fields.created,
      updated: issue.fields.updated,
      reporter: issue.fields.reporter?.displayName || 'Unknown',
      project: issue.fields.project?.key || 'Unknown',
      issueType: issue.fields.issuetype?.name || 'Task',
      storyPoints: issue.fields.storypoints || 0,
      url: `${baseUrl}/browse/${issue.key}`,
      sprintId: sprintId
    }));

    res.json({ 
      tickets,
      total: response.data.total,
      sprintId: sprintId
    });

  } catch (error) {
    console.error('Error fetching sprint tickets:', error);
    handleApiError(error, res);
  }
});

// Search Jira tickets (enhanced to include project filtering)
app.post('/api/jira/search', async (req, res) => {
  try {
    const { jql, maxResults = 50 } = req.body;
    
    if (!jql) {
      return res.status(400).json({ error: 'JQL query is required' });
    }

    if (!jiraConfig) {
      return res.status(400).json({ error: 'Jira not configured. Please configure first.' });
    }

    const { baseUrl } = jiraConfig;

    const headers = {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    };

    const response = await axios.post(`${baseUrl}/rest/api/2/search`, {
      jql,
      maxResults,
      fields: [
        'summary',
        'description',
        'priority',
        'status',
        'assignee',
        'created',
        'updated',
        'reporter',
        'project',
        'issuetype',
        'sprint'
      ]
    }, {
      headers,
      timeout: 30000
    });

    const data = response.data;
    
    // Format the response
    const formattedIssues = data.issues.map(issue => ({
      key: issue.key,
      summary: issue.fields.summary,
      description: issue.fields.description?.content?.[0]?.content?.[0]?.text || 
                   issue.fields.description || 
                   'No description available',
      priority: issue.fields.priority?.name || 'None',
      status: issue.fields.status?.name || 'Unknown',
      assignee: issue.fields.assignee?.displayName || 'Unassigned',
      created: issue.fields.created,
      updated: issue.fields.updated,
      reporter: issue.fields.reporter?.displayName || 'Unknown',
      project: issue.fields.project?.key || 'Unknown',
      issueType: issue.fields.issuetype?.name || 'Task',
      url: `${baseUrl}/browse/${issue.key}`
    }));

    res.json({
      issues: formattedIssues,
      total: data.total,
      maxResults: data.maxResults
    });

  } catch (error) {
    console.error('Error searching Jira:', error);
    handleApiError(error, res);
  }
});

// Health check endpoint
app.get('/api/health', (req, res) => {
  res.json({ status: 'OK', message: 'Jira API server is running' });
});

app.listen(PORT, () => {
  console.log(`Jira API server running on port ${PORT}`);
  console.log(`Health check: http://localhost:${PORT}/api/health`);
});

module.exports = app;
