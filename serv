const express = require('express');
const cors = require('cors');
const axios = require('axios');

const app = express();
const PORT = process.env.PORT || 3001;

// Middleware
app.use(cors());
app.use(express.json());

// Store Jira configurations (in production, use a database)
let jiraConfigs = new Map();

// Configure Jira endpoint
app.post('/api/jira/configure', (req, res) => {
  const { baseUrl, username, apiToken, sessionId } = req.body;
  
  if (!baseUrl) {
    return res.status(400).json({ error: 'Base URL is required' });
  }

  // Store config with session ID as key
  const configId = sessionId || 'default';
  jiraConfigs.set(configId, {
    baseUrl: baseUrl.replace(/\/$/, ''), // Remove trailing slash
    username,
    apiToken
  });

  res.json({ success: true, message: 'Jira configuration saved' });
});

// Get all projects
app.get('/api/jira/projects', async (req, res) => {
  try {
    const { sessionId } = req.query;
    const configId = sessionId || 'default';
    const config = jiraConfigs.get(configId);
    
    if (!config) {
      return res.status(400).json({ error: 'Jira not configured. Please configure first.' });
    }

    const { baseUrl, username, apiToken } = config;

    // Prepare headers
    const headers = {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    };

    // Add authentication if provided
    if (username && apiToken) {
      headers['Authorization'] = `Basic ${Buffer.from(`${username}:${apiToken}`).toString('base64')}`;
    }

    const response = await axios.get(`${baseUrl}/rest/api/2/project`, {
      headers,
      timeout: 30000
    });

    const formattedProjects = response.data.map(project => ({
      key: project.key,
      name: project.name,
      id: project.id,
      projectTypeKey: project.projectTypeKey,
      lead: project.lead?.displayName || 'Unknown'
    }));

    res.json({ projects: formattedProjects });

  } catch (error) {
    console.error('Error fetching projects:', error);
    
    if (error.response) {
      const errorMessage = error.response.data?.errorMessages?.[0] || 
                           error.response.data?.message || 
                           `HTTP ${error.response.status}: ${error.response.statusText}`;
      
      return res.status(error.response.status).json({ 
        error: errorMessage,
        details: error.response.data 
      });
    } else if (error.request) {
      return res.status(503).json({ 
        error: 'Unable to connect to Jira server',
        message: 'Please check your Jira URL and network connection' 
      });
    } else {
      return res.status(500).json({ 
        error: 'Internal server error',
        message: error.message 
      });
    }
  }
});

// Get sprints for a project or board
app.get('/api/jira/sprints', async (req, res) => {
  try {
    const { projectKey, boardId, sessionId } = req.query;
    const configId = sessionId || 'default';
    const config = jiraConfigs.get(configId);
    
    if (!config) {
      return res.status(400).json({ error: 'Jira not configured. Please configure first.' });
    }

    const { baseUrl, username, apiToken } = config;

    // Prepare headers
    const headers = {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    };

    // Add authentication if provided
    if (username && apiToken) {
      headers['Authorization'] = `Basic ${Buffer.from(`${username}:${apiToken}`).toString('base64')}`;
    }

    let sprintsUrl;
    
    if (boardId) {
      // If board ID is provided, get sprints for that board
      sprintsUrl = `${baseUrl}/rest/agile/1.0/board/${boardId}/sprint`;
    } else if (projectKey) {
      // First get boards for the project, then get sprints
      const boardsResponse = await axios.get(
        `${baseUrl}/rest/agile/1.0/board?projectKeyOrId=${projectKey}`,
        { headers, timeout: 30000 }
      );
      
      if (boardsResponse.data.values.length === 0) {
        return res.json({ sprints: [], message: 'No boards found for this project' });
      }
      
      // Use the first board found
      const firstBoardId = boardsResponse.data.values[0].id;
      sprintsUrl = `${baseUrl}/rest/agile/1.0/board/${firstBoardId}/sprint`;
    } else {
      return res.status(400).json({ error: 'Either projectKey or boardId is required' });
    }

    const response = await axios.get(sprintsUrl, {
      headers,
      timeout: 30000
    });

    const formattedSprints = response.data.values.map(sprint => ({
      id: sprint.id,
      name: sprint.name,
      state: sprint.state,
      startDate: sprint.startDate,
      endDate: sprint.endDate,
      completeDate: sprint.completeDate,
      goal: sprint.goal || 'No goal set'
    }));

    res.json({ sprints: formattedSprints });

  } catch (error) {
    console.error('Error fetching sprints:', error);
    
    if (error.response) {
      const errorMessage = error.response.data?.errorMessages?.[0] || 
                           error.response.data?.message || 
                           `HTTP ${error.response.status}: ${error.response.statusText}`;
      
      return res.status(error.response.status).json({ 
        error: errorMessage,
        details: error.response.data 
      });
    } else if (error.request) {
      return res.status(503).json({ 
        error: 'Unable to connect to Jira server',
        message: 'Please check your Jira URL and network connection' 
      });
    } else {
      return res.status(500).json({ 
        error: 'Internal server error',
        message: error.message 
      });
    }
  }
});

// Get tickets for a specific sprint
app.get('/api/jira/sprint/:sprintId/issues', async (req, res) => {
  try {
    const { sprintId } = req.params;
    const { sessionId } = req.query;
    const configId = sessionId || 'default';
    const config = jiraConfigs.get(configId);
    
    if (!config) {
      return res.status(400).json({ error: 'Jira not configured. Please configure first.' });
    }

    const { baseUrl, username, apiToken } = config;

    // Prepare headers
    const headers = {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    };

    // Add authentication if provided
    if (username && apiToken) {
      headers['Authorization'] = `Basic ${Buffer.from(`${username}:${apiToken}`).toString('base64')}`;
    }

    const response = await axios.get(`${baseUrl}/rest/agile/1.0/sprint/${sprintId}/issue`, {
      headers,
      timeout: 30000
    });

    const formattedIssues = response.data.issues.map(issue => ({
      key: issue.key,
      summary: issue.fields.summary,
      description: issue.fields.description?.content?.[0]?.content?.[0]?.text || 
                   issue.fields.description || 
                   'No description available',
      priority: issue.fields.priority?.name || 'None',
      status: issue.fields.status?.name || 'Unknown',
      assignee: issue.fields.assignee?.displayName || 'Unassigned',
      created: issue.fields.created,
      updated: issue.fields.updated,
      reporter: issue.fields.reporter?.displayName || 'Unknown',
      project: issue.fields.project?.key || 'Unknown',
      issueType: issue.fields.issuetype?.name || 'Task',
      storyPoints: issue.fields.customfield_10016 || 0, // Common story points field
      url: `${baseUrl}/browse/${issue.key}`
    }));

    res.json({
      issues: formattedIssues,
      total: response.data.total
    });

  } catch (error) {
    console.error('Error fetching sprint issues:', error);
    
    if (error.response) {
      const errorMessage = error.response.data?.errorMessages?.[0] || 
                           error.response.data?.message || 
                           `HTTP ${error.response.status}: ${error.response.statusText}`;
      
      return res.status(error.response.status).json({ 
        error: errorMessage,
        details: error.response.data 
      });
    } else if (error.request) {
      return res.status(503).json({ 
        error: 'Unable to connect to Jira server',
        message: 'Please check your Jira URL and network connection' 
      });
    } else {
      return res.status(500).json({ 
        error: 'Internal server error',
        message: error.message 
      });
    }
  }
});

// Search Jira tickets (existing endpoint)
app.post('/api/jira/search', async (req, res) => {
  try {
    const { jql, maxResults = 50, sessionId } = req.body;
    
    if (!jql) {
      return res.status(400).json({ error: 'JQL query is required' });
    }

    const configId = sessionId || 'default';
    const config = jiraConfigs.get(configId);
    
    if (!config) {
      return res.status(400).json({ error: 'Jira not configured. Please configure first.' });
    }

    const { baseUrl, username, apiToken } = config;

    // Prepare headers
    const headers = {
      'Content-Type': 'application/json',
      'Accept': 'application/json'
    };

    // Add authentication if provided
    if (username && apiToken) {
      headers['Authorization'] = `Basic ${Buffer.from(`${username}:${apiToken}`).toString('base64')}`;
    }

    const response = await axios.post(`${baseUrl}/rest/api/2/search`, {
      jql,
      maxResults,
      fields: [
        'summary',
        'description',
        'priority',
        'status',
        'assignee',
        'created',
        'updated',
        'reporter',
        'project',
        'issuetype',
        'customfield_10016' // Story points
      ]
    }, {
      headers,
      timeout: 30000 // 30 second timeout
    });

    const data = response.data;
    
    // Format the response
    const formattedIssues = data.issues.map(issue => ({
      key: issue.key,
      summary: issue.fields.summary,
      description: issue.fields.description?.content?.[0]?.content?.[0]?.text || 
                   issue.fields.description || 
                   'No description available',
      priority: issue.fields.priority?.name || 'None',
      status: issue.fields.status?.name || 'Unknown',
      assignee: issue.fields.assignee?.displayName || 'Unassigned',
      created: issue.fields.created,
      updated: issue.fields.updated,
      reporter: issue.fields.reporter?.displayName || 'Unknown',
      project: issue.fields.project?.key || 'Unknown',
      issueType: issue.fields.issuetype?.name || 'Task',
      storyPoints: issue.fields.customfield_10016 || 0,
      url: `${baseUrl}/browse/${issue.key}`
    }));

    res.json({
      issues: formattedIssues,
      total: data.total,
      maxResults: data.maxResults
    });

  } catch (error) {
    console.error('Error searching Jira:', error);
    
    if (error.response) {
      // Axios error with response
      const errorMessage = error.response.data?.errorMessages?.[0] || 
                           error.response.data?.message || 
                           `HTTP ${error.response.status}: ${error.response.statusText}`;
      
      return res.status(error.response.status).json({ 
        error: errorMessage,
        details: error.response.data 
      });
    } else if (error.request) {
      // Network error
      return res.status(503).json({ 
        error: 'Unable to connect to Jira server',
        message: 'Please check your Jira URL and network connection' 
      });
    } else {
      // Other error
      return res.status(500).json({ 
        error: 'Internal server error',
        message: error.message 
      });
    }
  }
});

