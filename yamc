const fs = require('fs');
const path = require('path');
const imap = require('imap');
const { simpleParser } = require('mailparser');

const config = {
  imap: {
    user: 'your.name@goldmansachs.com',
    password: 'your-password',
    host: 'outlook.office365.com',
    port: 993,
    tls: true,
    tlsOptions: { 
      rejectUnauthorized: true
    },
    authTimeout: 30000,
    connTimeout: 60000,
    keepalive: true
  },
  mailbox: 'INBOX',  // Changed from 'emea' to 'INBOX'
  csvPath: path.join(__dirname, 'data', 'db.csv')
};

function fetchEmails() {
  return new Promise((resolve) => {
    const imapClient = new imap(config.imap);
    const emails = [];
    let connectionTimedOut = false;
    
    const connectionTimeout = setTimeout(() => {
      connectionTimedOut = true;
      console.error('Connection timed out after 2 minutes');
      imapClient.end();
      resolve([]);
    }, 120000);
    
    imapClient.once('ready', () => {
      clearTimeout(connectionTimeout);
      
      imapClient.openBox(config.mailbox, false, (err) => {
        if (err) {
          console.error(`Error opening mailbox "${config.mailbox}":`, err);
          imapClient.end();
          return resolve([]);
        }
        
        console.log(`Successfully opened mailbox: ${config.mailbox}`);

        // Search for all UNSEEN emails in the inbox
        imapClient.search(['UNSEEN'], (err, results) => {
          if (err) {
            console.error('Error during search:', err);
            imapClient.end();
            return resolve([]);
          }
          
          if (!results.length) {
            console.log('No unread emails found');
            imapClient.end();
            return resolve([]);
          }
          
          console.log(`Found ${results.length} unread emails`);
          
          const fetch = imapClient.fetch(results, { bodies: '' });
          
          fetch.on('message', (msg) => {
            let emailData = {};
            msg.on('body', (stream) => {
              simpleParser(stream, (err, mail) => {
                if (err) {
                  console.error('Error parsing email:', err);
                  return;
                }
                
                emailData = {
                  subject: mail.subject || 'No Subject',
                  body: mail.text || '',
                  from: mail.from?.value[0]?.address || 'Unknown',
                  date: mail.date?.toISOString() || new Date().toISOString()
                };
              });
            });
            
            msg.once('end', () => {
              emails.push(emailData);
            });
          });
          
          fetch.once('end', () => {
            console.log('Finished fetching all messages');
            imapClient.end();
            resolve(emails);
          });
        });
      });
    });

    imapClient.once('error', (err) => {
      clearTimeout(connectionTimeout);
      console.error('IMAP connection error:', err);
      resolve([]);
    });
    
    imapClient.once('end', () => {
      clearTimeout(connectionTimeout);
      if (!connectionTimedOut) {
        console.log('IMAP connection ended');
      }
    });

    console.log('Attempting to connect to email server...');
    imapClient.connect();
  });
}

function appendToCSV(emails) {
  if (!emails.length) {
    console.log('No emails to append to CSV');
    return;
  }
  
  try {
    if (!fs.existsSync(path.dirname(config.csvPath))) {
      fs.mkdirSync(path.dirname(config.csvPath), { recursive: true });
    }
    
    const header = !fs.existsSync(config.csvPath) ? 'Subject,Body,From,Date\n' : '';
    const lines = emails.map(e => 
      `"${e.subject.replace(/"/g, '""')}","${e.body.replace(/"/g, '""')}","${e.from}","${e.date}"`
    ).join('\n');
    
    fs.appendFileSync(config.csvPath, header + lines + '\n');
    console.log(`Successfully added ${emails.length} new unread emails to CSV`);
  } catch (error) {
    console.error('Error writing to CSV:', error);
  }
}

async function sync() {
  console.log('Starting sync process at', new Date().toLocaleString());
  try {
    const emails = await fetchEmails();
    appendToCSV(emails);
  } catch (error) {
    console.error('Sync process error:', error);
  }
  console.log('Sync process completed at', new Date().toLocaleString());
}

// Run immediately and then schedule
console.log('Email monitoring script started');
sync();
setInterval(sync, 60 * 60 * 1000);
