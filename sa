import unittest
import requests
import pandas as pd
import time
import json
import os
from sklearn.metrics import precision_recall_curve, average_precision_score
from pathlib import Path
import matplotlib.pyplot as plt
import numpy as np

class fm(unittest.TestCase):
    
    BASE_URL = "http://127.0.0.1:8000"
    SAMPLE_DATA_SIZE = 100
    TEST_QUERIES = [
        "Budget planning for Q3",
        "Meeting with clients tomorrow",
        "Project deadline extension",
        "New hire onboarding process",
        "Marketing campaign results",
        "did we have any prod issues in jan 2025",
        "who were OOO in march 2025"
    ]
    
    @classmethod
    def setUpClass(cls):
        Path("test_results").mkdir(exist_ok=True)
        
        try:
            requests.post(f"{cls.BASE_URL}/preprocess")
        except requests.exceptions.ConnectionError:
            raise ConnectionError(f"API not available at {cls.BASE_URL}. Please start the server.")
    
    def test_response_time(self):
        response_times = []
        
        for query in self.TEST_QUERIES:
            start_time = time.time()
            response = requests.post(
                f"{self.BASE_URL}/generate",
                json={"query": query, "top_k": 10}
            )
            end_time = time.time()
            self.assertEqual(response.status_code, 200)
            response_times.append(end_time - start_time)
        
        avg_response_time = sum(response_times) / len(response_times)
        max_response_time = max(response_times)
        
        metrics = {
            "avg_response_time_seconds": avg_response_time,
            "max_response_time_seconds": max_response_time,
            "response_times": response_times
        }
        
        with open("test_results/response_time_metrics.json", "w") as f:
            json.dump(metrics, f, indent=2)
        
        print(f"Average response time: {avg_response_time:.4f} seconds")
        print(f"Maximum response time: {max_response_time:.4f} seconds")
        
        self.assertLess(avg_response_time, 1.0)
        self.assertLess(max_response_time, 2.0)
    
    def test_retrieval_accuracy(self):
        ground_truth = {
            "Budget planning for Q3": ["email123", "email456", "email789"],
            "Meeting with clients tomorrow": ["email234", "email567"],
            "did we have any prod issues in jan 2025": ["email345", "email678", "email901"],
            "who were OOO in march 2025": ["email456", "email789", "email012"]
        }
        
        precision_at_k = {}
        recall_at_k = {}
        
        for query, relevant_ids in ground_truth.items():
            response = requests.post(
                f"{self.BASE_URL}/generate",
                json={"query": query, "top_k": 10}
            )
            self.assertEqual(response.status_code, 200)
            
            results = response.json()["matches"]
            retrieved_ids = [f"email{match['email_data']['index']}" for match in results]
            
            for k in [1, 3, 5, 10]:
                retrieved_at_k = retrieved_ids[:k]
                relevant_retrieved = set(retrieved_at_k).intersection(set(relevant_ids))
                
                precision = len(relevant_retrieved) / k if k > 0 else 0
                recall = len(relevant_retrieved) / len(relevant_ids) if relevant_ids else 1
                
                if k not in precision_at_k:
                    precision_at_k[k] = []
                if k not in recall_at_k:
                    recall_at_k[k] = []
                
                precision_at_k[k].append(precision)
                recall_at_k[k].append(recall)
        
        avg_precision = {k: sum(v)/len(v) for k, v in precision_at_k.items()}
        avg_recall = {k: sum(v)/len(v) for k, v in recall_at_k.items()}
        
        metrics = {
            "precision_at_k": avg_precision,
            "recall_at_k": avg_recall
        }
        
        with open("test_results/retrieval_accuracy_metrics.json", "w") as f:
            json.dump(metrics, f, indent=2)
        
        print(f"Precision@1: {avg_precision[1]:.4f}, Recall@1: {avg_recall[1]:.4f}")
        print(f"Precision@5: {avg_precision[5]:.4f}, Recall@5: {avg_recall[5]:.4f}")
        
        self.assertGreater(avg_precision[5], 0.7)
        self.assertGreater(avg_recall[5], 0.5)
    
    def test_relevance_distribution(self):
        all_scores = []
        
        for query in self.TEST_QUERIES:
            response = requests.post(
                f"{self.BASE_URL}/generate",
                json={"query": query, "top_k": 10}
            )
            self.assertEqual(response.status_code, 200)
            
            results = response.json()["matches"]
            scores = [match["similarity_score"] for match in results]
            all_scores.extend(scores)
        
        avg_score = sum(all_scores) / len(all_scores) if all_scores else 0
        min_score = min(all_scores) if all_scores else 0
        max_score = max(all_scores) if all_scores else 0
        
        metrics = {
            "avg_similarity_score": avg_score,
            "min_similarity_score": min_score,
            "max_similarity_score": max_score,
            "score_distribution": all_scores
        }
        
        with open("test_results/relevance_distribution_metrics.json", "w") as f:
            json.dump(metrics, f, indent=2)
        
        plt.figure(figsize=(10, 6))
        plt.hist(all_scores, bins=20)
        plt.title('Distribution of Similarity Scores')
        plt.xlabel('Similarity Score')
        plt.ylabel('Frequency')
        plt.savefig("test_results/similarity_score_distribution.png")
        
        print(f"Average similarity score: {avg_score:.4f}")
        print(f"Min similarity score: {min_score:.4f}")
        print(f"Max similarity score: {max_score:.4f}")
        
        self.assertGreater(avg_score, 0.5)
    
    def test_conversation_threading_accuracy(self):
        response = requests.post(
            f"{self.BASE_URL}/generate",
            json={"query": "Project status update", "top_k": 10}
        )
        self.assertEqual(response.status_code, 200)
        
        results = response.json()["matches"]
        subjects = [match["email_data"]["Subject"] for match in results]
        cleaned_subjects = [match["email_data"]["cleaned_subject"] for match in results]
        
        thread_count = {}
        for subject in cleaned_subjects:
            if subject not in thread_count:
                thread_count[subject] = 0
            thread_count[subject] += 1
        
        thread_metrics = {
            "unique_threads": len(thread_count),
            "thread_distribution": thread_count,
            "max_thread_size": max(thread_count.values()) if thread_count else 0
        }
        
        with open("test_results/conversation_threading_metrics.json", "w") as f:
            json.dump(thread_metrics, f, indent=2)
        
        print(f"Unique threads: {thread_metrics['unique_threads']}")
        print(f"Max thread size: {thread_metrics['max_thread_size']}")
        
        self.assertLessEqual(thread_metrics['unique_threads'], 5)

    def test_system_load(self):
        concurrent_requests = 5
        response_times = []
        
        for _ in range(3):
            start_time = time.time()
            
            for _ in range(concurrent_requests):
                response = requests.post(
                    f"{self.BASE_URL}/generate",
                    json={"query": "Important business update", "top_k": 10}
                )
                self.assertEqual(response.status_code, 200)
            
            end_time = time.time()
            batch_time = end_time - start_time
            response_times.append(batch_time / concurrent_requests)
        
        avg_response_time = sum(response_times) / len(response_times)
        
        load_metrics = {
            "concurrent_requests": concurrent_requests,
            "avg_response_time_per_request": avg_response_time,
            "response_times": response_times
        }
        
        with open("test_results/system_load_metrics.json", "w") as f:
            json.dump(load_metrics, f, indent=2)
        
        print(f"Average response time under load: {avg_response_time:.4f} seconds")
        
        self.assertLess(avg_response_time, 2.0)

    def test_dashboard_metrics(self):
        all_metrics = {}
        
        metric_files = [f for f in os.listdir("test_results") if f.endswith("_metrics.json")]
        for file in metric_files:
            with open(f"test_results/{file}", "r") as f:
                metrics = json.load(f)
                metric_name = file.replace("_metrics.json", "")
                all_metrics[metric_name] = metrics
        
        dashboard = {
            "response_time": {
                "avg": all_metrics.get("response_time", {}).get("avg_response_time_seconds", 0),
                "max": all_metrics.get("response_time", {}).get("max_response_time_seconds", 0)
            },
            "retrieval_accuracy": {
                "precision@5": all_metrics.get("retrieval_accuracy", {}).get("precision_at_k", {}).get("5", 0),
                "recall@5": all_metrics.get("retrieval_accuracy", {}).get("recall_at_k", {}).get("5", 0)
            },
            "relevance": {
                "avg_score": all_metrics.get("relevance_distribution", {}).get("avg_similarity_score", 0)
            },
            "threading": {
                "unique_threads": all_metrics.get("conversation_threading", {}).get("unique_threads", 0),
                "max_thread_size": all_metrics.get("conversation_threading", {}).get("max_thread_size", 0)
            },
            "system_load": {
                "avg_load_time": all_metrics.get("system_load", {}).get("avg_response_time_per_request", 0)
            }
        }
        
        with open("test_results/dashboard_metrics.json", "w") as f:
            json.dump(dashboard, f, indent=2)
        
        print("Dashboard metrics generated successfully")

if __name__ == "__main__":
    unittest.main()
