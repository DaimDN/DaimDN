const {exec, spawn} = require('child_process');
const os = require('os');

const args = process.argv.slice(2);
let port = '8002';
let host = '0.0.0.0';

for (let i = 0; i < args.length; i++) {
  if (args[i] === '--port' && args[i + 1]) {
    port = args[i + 1];
    i++;
  } else if (args[i] === '--host' && args[i + 1]) {
    host = args[i + 1];
    i++;
  }
}

function closeBrowserTab() {
  const platform = os.platform();

  if (platform === 'darwin') {
    const appleScript = `
      tell application "Google Chrome"
        set tabList to {}
        set windowList to every window
        repeat with aWindow in windowList
          set tabList to every tab of aWindow
          repeat with aTab in tabList
            if URL of aTab contains "localhost:${port}" or URL of aTab contains "${host}:${port}" then
              delete aTab
            end if
          end repeat
        end repeat
      end tell
    `;

    exec(`osascript -e '${appleScript}'`, (error) => {
      if (error) {
        console.error('Error closing Chrome tab:', error);
      } else {
        console.log('Chrome tab closed successfully');
      }
    });
  } else if (platform === 'win32') {
    const powershell = `
      Add-Type -AssemblyName System.Windows.Forms
      Add-Type -AssemblyName Microsoft.VisualBasic
      $wshell = New-Object -ComObject wscript.shell
      $wshell.AppActivate('Chrome')
      Start-Sleep -Milliseconds 500
      [System.Windows.Forms.SendKeys]::SendWait("^f")
      Start-Sleep -Milliseconds 500
      [System.Windows.Forms.SendKeys]::SendWait("localhost:${port}")
      Start-Sleep -Milliseconds 500
      [System.Windows.Forms.SendKeys]::SendWait("{ESC}")
      Start-Sleep -Milliseconds 500
      [System.Windows.Forms.SendKeys]::SendWait("^w")
    `;

    exec(`powershell -Command "${powershell}"`, (error) => {
      if (error) {
        console.error('Error closing Chrome tab:', error);
      } else {
        console.log('Chrome tab closed successfully');
      }
    });
  } else if (platform === 'linux') {
    exec(
      `
      xdotool search --name "Chrome" windowactivate --sync key ctrl+l && 
      xdotool type "localhost:${port}" &&
      xdotool key Return &&
      xdotool key ctrl+w
    `,
      (error) => {
        if (error) {
          console.error('Error closing Chrome tab:', error);
        } else {
          console.log('Chrome tab closed successfully');
        }
      }
    );
  }
}

console.log('Starting Playwright UI server...');
const playwrightProcess = spawn(
  'npx',
  ['playwright', 'test', '--ui-port=' + port, '--ui-host=' + host],
  {
    stdio: 'inherit'
  }
);

setTimeout(() => {
  console.log('Attempting to close Chrome tab...');
  closeBrowserTab();
}, 1200);

console.log(`Playwright UI server running at http://${host}:${port}`);
console.log('Any Chrome tabs opening with this URL will be automatically closed');
console.log('Press Ctrl+C to stop the server');

process.on('SIGINT', () => {
  playwrightProcess.kill();
  console.log('Playwright UI server stopped');
  process.exit(0);
});
