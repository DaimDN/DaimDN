FROM jctae-publish.prod.aws.jpmchase.net/container-base/managedbaseimages/python:3.10.7-20221108164320

# ===== SYSTEM SETUP =====
# Install dependencies as root
RUN microdnf update -y && \
    microdnf install -y gettext curl gcc make openssl-devel bzip2-devel libffi-devel zlib-devel tar gzip xz-devel shadow-utils && \
    microdnf clean all

# Create non-root user/group FIRST (before any permission changes)
RUN groupadd -r webgroup && \
    useradd -r -g webgroup -d /app -s /sbin/nologin webuser && \
    mkdir -p /app && \
    chown webuser:webgroup /app

# ===== PYTHON INSTALLATION =====
ADD Python-3.13.1.tgz .
RUN cd Python-3.13.1 && \
    ./configure && \
    make && \
    make install && \
    ln -sf /usr/local/bin/python3.13 /usr/bin/python3
RUN python3 -m ensurepip --upgrade
RUN python3 --version

# ===== NODE.JS INSTALLATION =====
COPY node.tar.gz /tmp/
RUN tar -xzf /tmp/node.tar.gz -C /usr/local --strip-components=1 --no-same-owner && \
    rm /tmp/node.tar.gz && \
    ln -sf /usr/local/bin/node /usr/bin/node && \
    ln -sf /usr/local/bin/npm /usr/bin/npm
ENV PATH="/usr/local/bin:${PATH}"
RUN node --version && npm --version

# ===== APPLICATION SETUP =====
WORKDIR /app
COPY --chown=webuser:webgroup . .

# Install dependencies as root temporarily
RUN npm config set registry https://artifacts-read.gko.jpmchase.net/artifactory/api/npm/npm/ && \
    chown -R webuser:webgroup /app

# Switch to non-root user for runtime
USER webuser:webgroup

# Install Node modules (now with correct permissions)
RUN npm install && \
    cd client && \
    npm run build

EXPOSE 8801
CMD ["npm", "run", "prod"]
