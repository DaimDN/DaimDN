
# ===== SYSTEM SETUP =====
# Install dependencies as root
RUN microdnf update -y && \
    microdnf install -y gettext curl gcc make openssl-devel bzip2-devel libffi-devel zlib-devel tar gzip xz-devel && \
    microdnf clean all

# Create non-root user/group
RUN groupadd -r webgroup && useradd -r -g webgroup webuser

# ===== PYTHON INSTALLATION =====
ADD Python-3.13.1.tgz .
RUN cd Python-3.13.1 && \
    ./configure && \
    make && \
    make install && \
    ln -sf /usr/local/bin/python3.13 /usr/bin/python3
RUN python3 -m ensurepip --upgrade
RUN python3 --version

# ===== NODE.JS INSTALLATION =====
COPY --chown=webuser:webgroup node.tar.gz /tmp/
RUN tar -xzf /tmp/node.tar.gz -C /usr/local --strip-components=1 --no-same-owner && \
    rm /tmp/node.tar.gz && \
    ln -sf /usr/local/bin/node /usr/bin/node && \
    ln -sf /usr/local/bin/npm /usr/bin/npm
ENV PATH="/usr/local/bin:${PATH}"
RUN node --version && npm --version

# ===== PERMISSION FIXES =====
WORKDIR /app
COPY --chown=webuser:webgroup . .
RUN chmod -R 755 /app && \
    chown -R webuser:webgroup /app

# ===== APPLICATION SETUP =====
# Python dependencies
RUN python3 -m pip install --upgrade pip && \
    python3 -m pip install --index-url url -r requirements.txt

# Node.js dependencies
RUN npm config set registry url
WORKDIR /app/client
RUN npm install && npm run build
WORKDIR /app
RUN npm install

# ===== RUNTIME CONFIG =====
USER webuser:webgroup
EXPOSE 8801
HEALTHCHECK --interval=30s --timeout=3s CMD curl -f http://localhost:8801/health || exit 1
CMD ["npm", "run", "prod"]
